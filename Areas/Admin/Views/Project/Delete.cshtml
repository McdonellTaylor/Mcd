@model CUTDataScienceClub.Models.Project

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/members.css" />

<div class="members-bg" style="min-height:65vh; padding-top:2.5rem;">
    <div class="container members-container">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-8">
                <div class="member-card p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="card-avatar" style="width:64px;height:64px;font-size:20px;">@((Model?.Title ?? "").Split(' ').Select(s => s.FirstOrDefault()).Where(c => c!=0).Take(2).Aggregate("", (a,b) => a + b).ToUpper())</div>
                        <div class="ms-3">
                            <h3 class="mb-0">Delete Event</h3>
                            <div class="text-muted small">Are you sure you want to delete this event?</div>
                        </div>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Title</dt>
                        <dd class="col-sm-8">@(Model?.Title ?? "")</dd>

                        <dt class="col-sm-4">Start</dt>
                        <dd class="col-sm-8">@(Model?.StartDate.HasValue == true ? Model.StartDate.Value.ToString("yyyy-MM-dd HH:mm") : "")</dd>
                    </dl>

                    <form asp-area="Admin" asp-controller="Event" asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <a asp-area="Admin" asp-controller="Project" asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
