@model CUTDataScienceClub.Models.Member
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/members.css" />

<div class="members-bg" style="min-height:70vh; padding-top:2.5rem;">
    <div class="container members-container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="member-card p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="card-avatar" style="width:56px;height:56px;font-size:20px;">@((Model?.FullName ?? "New").Split(' ').Select(s => s.FirstOrDefault()).Where(c => c!=0).Take(2).Aggregate("", (a,b) => a + b).ToUpper())</div>
                        <div class="ms-3">
                            <h3 class="mb-0">@((Model?.Id == 0) ? "Create Member" : "Edit Member")</h3>
                            <div class="text-muted small">Fill in the details below</div>
                        </div>
                    </div>

                    <form asp-area="Admin" asp-controller="Member" asp-action="Upsert" method="post" class="row g-3">
                        <input type="hidden" asp-for="Id" />

                        <div class="col-12">
                            <label class="form-label">Full name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-0"><i class="bi bi-person-fill" style="color:#e6eef8"></i></span>
                                <input asp-for="FullName" class="form-control form-control-lg card-input" placeholder="e.g. Jane Doe" />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Registration #</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-0"><i class="bi bi-card-heading" style="color:#e6eef8"></i></span>
                                <input asp-for="RegNumber" class="form-control card-input" placeholder="DSC001" />
                            </div>
                            <span asp-validation-for="RegNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Program</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-0"><i class="bi bi-journal-bookmark" style="color:#e6eef8"></i></span>
                                <input asp-for="Program" class="form-control card-input" placeholder="Data Science" />
                            </div>
                            <span asp-validation-for="Program" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Current Level</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-0"><i class="bi bi-bar-chart" style="color:#e6eef8"></i></span>
                                <input asp-for="CurrentLevel" class="form-control card-input" placeholder="100" />
                            </div>
                            <span asp-validation-for="CurrentLevel" class="text-danger"></span>
                        </div>

                        <div class="col-12 d-flex gap-2 justify-content-end mt-3">
                            <a asp-area="Admin" asp-controller="Member" asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn create-btn">Save</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
