@model CUTDataScienceClub.Models.Member

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/members.css" />

<div class="members-bg" style="min-height:65vh; padding-top:2.5rem;">
    <div class="container members-container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="member-card p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="card-avatar" style="width:56px;height:56px;font-size:20px;">@((Model?.FullName ?? "").Split(' ').Select(s => s.FirstOrDefault()).Where(c => c!=0).Take(2).Aggregate("", (a,b) => a + b).ToUpper())</div>
                        <div class="ms-3">
                            <h3 class="mb-0">Delete Member</h3>
                            <div class="text-muted small">Are you sure you want to delete this member?</div>
                        </div>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Full name</dt>
                        <dd class="col-sm-8">@(Model?.FullName ?? "")</dd>

                        <dt class="col-sm-4">Registration #</dt>
                        <dd class="col-sm-8">@(Model?.RegNumber ?? "")</dd>
                    </dl>

                    <form asp-area="Admin" asp-controller="Member" asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <a asp-area="Admin" asp-controller="Member" asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
