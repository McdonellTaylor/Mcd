@model CUTDataScienceClub.Models.Event

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/members.css" />

<div class="members-bg" style="min-height:65vh; padding-top:2.5rem;">
    <div class="container members-container">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-8">
                <div class="member-card p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="card-avatar" style="width:64px;height:64px;font-size:20px;">@((Model?.Title ?? "").Split(' ').Select(s => s.FirstOrDefault()).Where(c => c!=0).Take(2).Aggregate("", (a,b) => a + b).ToUpper())</div>
                        <div class="ms-3">
                            <h3 class="mb-0">@(Model?.Title ?? "")</h3>
                            <div class="text-muted small">Event details</div>
                        </div>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@(Model?.Description ?? "")</dd>

                        <dt class="col-sm-4">Location</dt>
                        <dd class="col-sm-8">@(Model?.Location ?? "")</dd>

                        <dt class="col-sm-4">Start</dt>
                        <dd class="col-sm-8">@(Model != null ? Model.StartDate.ToString("yyyy-MM-dd HH:mm") : "")</dd>

                        <dt class="col-sm-4">End</dt>
                        <dd class="col-sm-8">@(Model?.EndDate.HasValue == true ? Model.EndDate.Value.ToString("yyyy-MM-dd HH:mm") : "")</dd>

                        <dt class="col-sm-4">Organizer</dt>
                        <dd class="col-sm-8">@(Model?.Organizer ?? "")</dd>

                        <dt class="col-sm-4">Published</dt>
                        <dd class="col-sm-8">@(Model?.IsPublished == true ? "Yes" : "No")</dd>
                    </dl>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a asp-area="Admin" asp-controller="Event" asp-action="Upsert" asp-route-id="@(Model?.Id ?? 0)" class="btn btn-outline-light btn-icon"><i class="bi bi-pencil-fill"></i><span class="btn-label">Edit</span></a>
                        <a asp-area="Admin" asp-controller="Event" asp-action="Index" class="btn btn-secondary">Back</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
