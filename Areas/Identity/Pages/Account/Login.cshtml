@page
@model LoginModel
@{
    ViewData["Title"] = "Welcome back";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body row g-0">
                    <div class="col-md-5 d-flex align-items-center justify-content-center bg-light">
                        <div class="text-center p-4">
                            <h4 class="mb-2">Welcome back</h4>
                            <p class="text-muted small">Sign in to access your dashboard and member features.</p>
                            <img src="/img/login-illustration.svg" alt="login" class="img-fluid" style="max-height:160px;" />
                        </div>
                    </div>
                    <div class="col-md-7 p-4">
                        <form id="account" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label"></label>
                                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="you@example.com" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label"></label>
                                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>

                            <div class="mb-3 form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
                            </div>

                            <div class="d-grid mb-2">
                                <button id="login-submit" type="submit" class="btn btn-primary btn-lg">Sign in</button>
                            </div>

                            <div class="d-flex justify-content-between small">
                                <a asp-page="./ForgotPassword">Forgot password?</a>
                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
                            </div>

                            <hr />

                            <div class="text-center small text-muted mb-2">Or sign in with</div>
                            <div class="text-center">
                                @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                {
                                    <span class="text-muted">No external providers configured</span>
                                }
                                else
                                {
                                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="d-inline">
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit" class="btn btn-outline-primary me-2" name="provider" value="@provider.Name">@provider.DisplayName</button>
                                        }
                                    </form>
                                }
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
