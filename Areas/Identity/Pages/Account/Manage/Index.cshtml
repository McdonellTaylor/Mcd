@page
@model IndexModel
@{
    ViewData["Title"] = "Your profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="container py-4">
    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-4 text-center border-end">
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.Input.ProfilePicture))
                        {
                            <img id="profilePreview" src="/ProfilePictureUploads/@Model.Input.ProfilePicture" class="rounded-circle img-fluid" style="width:160px;height:160px;object-fit:cover;" alt="Profile picture" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center" style="width:160px;height:160px;">
                                <span class="text-white fs-2">@(Model.Username?.Substring(0,1).ToUpper() ?? "U")</span>
                            </div>
                        }
                    </div>
                    <h5 class="card-title mb-0">@Model.Input.Name</h5>
                    <p class="text-muted small">@Model.Username</p>
                    <div class="mt-3 d-grid gap-2">
                        <a class="btn btn-outline-primary" asp-page="./ChangePassword">Change password</a>
                        <a class="btn btn-outline-secondary" asp-page="./PersonalData">Export personal data</a>
                    </div>
                </div>

                <div class="col-md-8">
                    <form id="profile-form" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Username</label>
                                <input asp-for="Username" class="form-control" disabled />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.Name" class="form-label"></label>
                                <input asp-for="Input.Name" class="form-control" placeholder="Full name" />
                                <span asp-validation-for="Input.Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Phone number" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Input.ImageFile" class="form-label">Profile picture</label>
                                <input asp-for="Input.ImageFile" type="file" accept="image/*" class="form-control" id="imageInput" />
                                <div class="form-text">Upload a square image for best results. Max recommended size 2MB.</div>
                            </div>

                            <div class="col-12 text-end">
                                <button id="update-profile-button" type="submit" class="btn btn-primary">Save changes</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const input = document.getElementById('imageInput');
            const preview = document.getElementById('profilePreview');

            if (!input) return;

            input.addEventListener('change', function (e) {
                const file = input.files && input.files[0];
                if (!file) return;
                if (!file.type.startsWith('image/')) return;

                const reader = new FileReader();
                reader.onload = function (ev) {
                    if (preview) {
                        preview.src = ev.target.result;
                    } else {
                        // If there was no preview element (no existing picture), create one
                        const img = document.createElement('img');
                        img.id = 'profilePreview';
                        img.className = 'rounded-circle';
                        img.style.width = '160px';
                        img.style.height = '160px';
                        img.style.objectFit = 'cover';
                        img.src = ev.target.result;
                        const container = input.closest('.card').querySelector('.col-md-4');
                        if (container) container.insertBefore(img, container.firstChild);
                    }
                };
                reader.readAsDataURL(file);
            });
        })();
    </script>
}
