@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h3 class="card-title mb-3">Sign out</h3>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <p class="text-muted">You are currently signed in. Do you want to sign out now?</p>
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                            <button type="submit" class="btn btn-danger">Sign out</button>
                            <a class="btn btn-secondary ms-2" href="@Url.Page("/", new { area = "" })">Cancel</a>
                        </form>
                    }
                    else
                    {
                        <p class="text-success">You have successfully logged out.</p>
                        <a class="btn btn-primary" href="@Url.Page("/", new { area = "" })">Return to home</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
