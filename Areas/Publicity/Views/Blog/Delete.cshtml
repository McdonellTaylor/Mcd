@model CUTDataScienceClub.Models.Blog

@{
    ViewData["Title"] = "Delete Blog";
}

<link rel="stylesheet" href="~/css/blogs.css" />

<section class="blog-hero">
    <div class="hero-inner">
        <h1>Delete Blog</h1>
        <p class="lead">You're about to permanently delete this blog post. This action cannot be undone.</p>
    </div>
</section>

<section style="padding:20px;">
    <div class="blog-item" style="max-width:900px;margin:0 auto;padding:0;">
        <div class="media-wrap">
            @if (!string.IsNullOrEmpty(Model?.VideoUrl))
            {
                <video controls style="width:100%;height:auto;display:block;background:#000;">
                    <source src="@Model.VideoUrl" />
                </video>
            }
            else if (!string.IsNullOrEmpty(Model?.ImageUrl))
            {
                <div class="image-thumb" style="height:280px;background-image:url('@Model.ImageUrl');background-size:cover;background-position:center"></div>
            }
            else
            {
                <div class="image-thumb placeholder" style="height:280px;display:flex;align-items:center;justify-content:center;color:var(--muted);">No media</div>
            }
        </div>

        <div class="blog-body">
            <h2 class="blog-title">@Model?.Title</h2>
            <div class="meta">by <strong>@Model?.Author</strong> <span class="dot">•</span> @Model?.PublishedDate?.ToString("MMM d, yyyy")</div>

            <p class="excerpt" style="margin-top:12px;">@Model?.Excerpt</p>

            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:18px;">
                <a asp-area="Publicity" asp-controller="Blog" asp-action="Details" asp-route-id="@(Model?.Id ?? 0)" class="btn btn-outline">Back</a>

                <form asp-area="Publicity" asp-controller="Blog" asp-action="DeleteConfirmed" method="post" onsubmit="return confirm('Delete this blog post?');" class="delete-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@(Model?.Id ?? 0)" />
                    <button type="submit" class="btn btn-danger">Delete permanently</button>
                </form>
            </div>
        </div>
    </div>
</section>
